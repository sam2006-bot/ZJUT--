# Fill in your own OpenAI-compatible proxy configuration here.
OPENAI_API_KEY=
OPENAI_MODEL=claude-model-name-from-your-provider
OPENAI_BASE_URL=https://your-openai-compatible-proxy.example/v1
OPENAI_API_PATH=/chat/completions
OPENAI_API_AUTH_MODE=bearer
OPENAI_API_AUTH_HEADER=
OPENAI_API_AUTH_PREFIX=

# Optional: invite-only access control
INVITE_CODES=
INVITE_SESSION_SECRET=

# Optional: local server host/port
APP_HOST=0.0.0.0
APP_PORT=8000
